# NetBrain MCP Server Configuration
# Copy this file to .env and fill in your values.

NETBRAIN_URL=https://your-netbrain-instance.example.com
NETBRAIN_USERNAME=your-api-username
NETBRAIN_PASSWORD=your-api-password
NETBRAIN_DOMAIN=your-domain-name
NETBRAIN_TENANT=

# Optional tuning
# NETBRAIN_AUTH_TIMEOUT=30
# NETBRAIN_POLL_INTERVAL=2.0
# NETBRAIN_POLL_TIMEOUT=30.0
